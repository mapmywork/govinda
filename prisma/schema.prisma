generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id          String   @id @default(uuid())
  make        String
  model       String
  year        Int
  price       Float
  type        String
  imageUrl    String?
  features    String   // Store as JSON string or comma separated for simplicity in SQLite
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}
